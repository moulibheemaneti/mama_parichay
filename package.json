{
   "name": "mama_parichay",
   "version": "0.0.1",
   "type": "module",
   "private": true,
   "scripts": {
      "build": "bun --bun nuxt build",
      "dev": "bun --bun nuxt dev",
      "generate": "bun --bun nuxt generate",
      "preview": "bun --bun nuxt preview",
      "postinstall": "bun --bun nuxt prepare",
      "prepare": "husky",
      "lint": "eslint .; stylelint '**/*.scss'",
      "lint:fix": "eslint . --fix; stylelint --fix '**/*.scss'",
      "clean": "rm -rf .nuxt .output dist",
      "clean:all": "bun clean && rm -rf bun.lock"
   },
   "dependencies": {
      "@nuxt/eslint": "1.16.0",
      "eslint": "^9.0.0 || ^10.0.0",
      "nuxt": "^4.4.6",
      "vue": "^3.5.34",
      "vue-router": "^5.0.7"
   },
   "devDependencies": {
      "@commitlint/cli": "^21.0.1",
      "@commitlint/config-conventional": "^21.0.1",
      "@semantic-release/changelog": "^6.0.3",
      "@semantic-release/commit-analyzer": "^13.0.1",
      "@semantic-release/git": "^10.0.1",
      "@semantic-release/github": "^12.0.8",
      "@semantic-release/npm": "^13.1.5",
      "@semantic-release/release-notes-generator": "^14.1.1",
      "@stylistic/stylelint-plugin": "^5.2.0",
      "conventional-changelog-conventionalcommits": "^9.3.1",
      "husky": "^9.1.7",
      "sass": "^1.100.0",
      "semantic-release": "^25.0.3",
      "stylelint": "^17.12.0",
      "stylelint-config-standard": "^40.0.0",
      "stylelint-config-standard-scss": "^17.0.0"
   }
}
